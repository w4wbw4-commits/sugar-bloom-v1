{% extends 'layouts/master.twig' %}

{% block content %}
<section class="section-padding bg-background">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      {# Product Image #}
      <div class="relative rounded-3xl overflow-hidden" style="box-shadow: var(--shadow-product)">
        <img src="{{ product.image.url }}" alt="{{ product.name }}" class="w-full aspect-square object-cover">
        {% if product.discount_percentage > 0 %}
          <span class="absolute top-4 right-4 bg-primary text-primary-foreground text-sm font-bold px-3 py-1.5 rounded-full">
            خصم {{ product.discount_percentage }}%
          </span>
        {% endif %}
      </div>

      {# Product Details #}
      <div class="space-y-6">
        <div>
          <p class="font-body text-sm text-muted-foreground mb-2">{{ product.category.name }}</p>
          <h1 class="font-display text-3xl lg:text-4xl font-bold text-foreground">{{ product.name }}</h1>
        </div>

        <div class="flex items-center gap-3">
          <span class="font-display text-3xl font-bold text-primary">{{ product.price }} {{ currency }}</span>
          {% if product.regular_price != product.price %}
            <span class="font-body text-lg text-muted-foreground line-through">{{ product.regular_price }} {{ currency }}</span>
          {% endif %}
        </div>

        <div class="flex gap-0.5">
          {% for i in 1..5 %}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="{{ i <= product.rating ? 'currentColor' : 'none' }}" stroke="currentColor" class="{{ i <= product.rating ? 'text-rose-gold' : 'text-border' }}"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          {% endfor %}
        </div>

        <p class="font-body text-muted-foreground leading-relaxed">{{ product.description }}</p>

        {# Quantity & Add to Cart #}
        <div class="flex items-center gap-4">
          <div class="flex items-center border border-border rounded-full overflow-hidden">
            <button onclick="this.nextElementSibling.stepDown(); this.nextElementSibling.dispatchEvent(new Event('change'))" class="w-10 h-10 flex items-center justify-center hover:bg-secondary transition-colors">−</button>
            <input type="number" value="1" min="1" max="10" id="product-qty" class="w-12 text-center font-body font-semibold border-0 focus:outline-none bg-transparent">
            <button onclick="this.previousElementSibling.stepUp(); this.previousElementSibling.dispatchEvent(new Event('change'))" class="w-10 h-10 flex items-center justify-center hover:bg-secondary transition-colors">+</button>
          </div>
          <button onclick="salla.cart.addItem({ id: {{ product.id }}, quantity: document.getElementById('product-qty').value })" class="btn-sugar flex-1 text-base">أضيفي للسلة 🛍</button>
        </div>

        <button onclick="salla.wishlist.toggle({{ product.id }})" class="btn-sugar-outline w-full text-base">أضيفي للمفضلة ❤</button>
      </div>
    </div>
  </div>
</section>
{% endblock %}
