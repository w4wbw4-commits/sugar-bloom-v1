<div class="group bg-card rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1" style="box-shadow: var(--shadow-card)">
  <div class="relative aspect-square overflow-hidden">
    <img src="{{ product.image.url }}" alt="{{ product.name }}" loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">

    {% if product.discount_percentage > 0 %}
      <span class="absolute top-3 right-3 bg-primary text-primary-foreground text-xs font-bold px-2.5 py-1 rounded-full">
        خصم {{ product.discount_percentage }}%
      </span>
    {% endif %}

    {# Quick actions #}
    <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-2 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
      <button onclick="salla.wishlist.toggle({{ product.id }})" class="w-9 h-9 rounded-full bg-card/90 backdrop-blur-sm flex items-center justify-center hover:bg-primary hover:text-primary-foreground transition-colors" aria-label="أضيفي للمفضلة">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      </button>
      <button onclick="salla.cart.addItem({ id: {{ product.id }}, quantity: 1 })" class="w-9 h-9 rounded-full bg-primary text-primary-foreground flex items-center justify-center hover:scale-110 transition-transform" aria-label="أضيفي للسلة">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </button>
    </div>
  </div>

  <div class="p-4 text-center space-y-2">
    <a href="{{ product.url }}" class="font-body font-semibold text-foreground text-sm hover:text-primary transition-colors block">
      {{ product.name }}
    </a>
    <div class="flex justify-center gap-0.5">
      {% for i in 1..5 %}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="{{ i <= product.rating ? 'currentColor' : 'none' }}" stroke="currentColor" class="{{ i <= product.rating ? 'text-rose-gold' : 'text-border' }}"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      {% endfor %}
    </div>
    <div class="flex items-center justify-center gap-2">
      <span class="font-display font-bold text-primary text-lg">{{ product.price }} {{ currency }}</span>
      {% if product.regular_price != product.price %}
        <span class="font-body text-xs text-muted-foreground line-through">{{ product.regular_price }} {{ currency }}</span>
      {% endif %}
    </div>
  </div>
</div>
