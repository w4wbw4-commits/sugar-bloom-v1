<footer class="bg-foreground text-primary-foreground">
  <div class="container mx-auto px-4 py-12 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      {# Brand #}
      <div class="space-y-4">
        <h3 class="font-display text-2xl font-bold">
          {% if theme.settings.branding.logo %}
            <img src="{{ theme.settings.branding.logo }}" alt="{{ store.name }}" class="h-10">
          {% else %}
            {{ theme.settings.branding.store_name | default('Sugar') }} <span class="text-primary">Bloom</span> 🌸
          {% endif %}
        </h3>
        <p class="font-body text-sm opacity-70 leading-relaxed">{{ store.description }}</p>
        <div class="flex gap-3">
          {% if store.social.instagram %}
            <a href="{{ store.social.instagram }}" target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-primary-foreground/10 flex items-center justify-center hover:bg-primary transition-all duration-300 hover:scale-110">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if store.social.twitter %}
            <a href="{{ store.social.twitter }}" target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-primary-foreground/10 flex items-center justify-center hover:bg-primary transition-all duration-300 hover:scale-110">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
            </a>
          {% endif %}
          {% if store.social.tiktok %}
            <a href="{{ store.social.tiktok }}" target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-primary-foreground/10 flex items-center justify-center hover:bg-primary transition-all duration-300 hover:scale-110">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.73a8.19 8.19 0 0 0 4.76 1.52v-3.4a4.85 4.85 0 0 1-1-.16z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      {# Quick Links #}
      <div class="space-y-3">
        <h4 class="font-display font-bold text-lg">روابط سريعة</h4>
        <div class="flex flex-col gap-2 font-body text-sm opacity-70">
          <a href="{{ link('/') }}" class="hover:opacity-100 hover:text-primary transition-all duration-300">الرئيسية</a>
          <a href="{{ link('products') }}" class="hover:opacity-100 hover:text-primary transition-all duration-300">المنتجات</a>
          <a href="{{ link('wishlist') }}" class="hover:opacity-100 hover:text-primary transition-all duration-300">المفضلة</a>
          {% if customer %}
            <a href="{{ link('customer.account') }}" class="hover:opacity-100 hover:text-primary transition-all duration-300">حسابي</a>
          {% else %}
            <a href="{{ link('customer.login') }}" class="hover:opacity-100 hover:text-primary transition-all duration-300">تسجيل الدخول</a>
          {% endif %}
        </div>
      </div>

      {# Policies #}
      <div class="space-y-3">
        <h4 class="font-display font-bold text-lg">سياساتنا</h4>
        <div class="flex flex-col gap-2 font-body text-sm opacity-70">
          <a href="{{ link('page', 'return-policy') }}" class="hover:opacity-100 hover:text-primary transition-all duration-300">سياسة الاسترجاع</a>
          <a href="{{ link('page', 'shipping-policy') }}" class="hover:opacity-100 hover:text-primary transition-all duration-300">سياسة الشحن</a>
          <a href="{{ link('page', 'privacy-policy') }}" class="hover:opacity-100 hover:text-primary transition-all duration-300">سياسة الخصوصية</a>
          <a href="{{ link('page', 'terms') }}" class="hover:opacity-100 hover:text-primary transition-all duration-300">الشروط والأحكام</a>
        </div>
      </div>

      {# Contact #}
      <div class="space-y-3">
        <h4 class="font-display font-bold text-lg">تواصلي معنا</h4>
        <div class="flex flex-col gap-2 font-body text-sm opacity-70">
          <p>{{ theme.settings.footer.email | default('info@sugarbloom.sa') }}</p>
          <p>{{ theme.settings.footer.phone | default('+966 50 000 0000') }}</p>
          <p>{{ theme.settings.footer.address | default('الرياض، المملكة العربية السعودية') }}</p>
        </div>
      </div>
    </div>

    {# Payment Methods #}
    <div class="border-t border-primary-foreground/10 mt-8 pt-6">
      <div class="flex justify-center gap-4 mb-6">
        <div class="w-14 h-9 rounded-lg bg-primary-foreground/10 flex items-center justify-center text-xs font-bold opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0">Mada</div>
        <div class="w-14 h-9 rounded-lg bg-primary-foreground/10 flex items-center justify-center text-xs font-bold opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0">Visa</div>
        <div class="w-14 h-9 rounded-lg bg-primary-foreground/10 flex items-center justify-center text-xs font-bold opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0">STC</div>
        <div class="w-14 h-9 rounded-lg bg-primary-foreground/10 flex items-center justify-center text-xs font-bold opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0">Apple</div>
      </div>
    </div>

    <div class="text-center font-body text-xs opacity-50">
      <p>© {{ 'now' | date('Y') }} {{ store.name }}. جميع الحقوق محفوظة ❤</p>
      <p class="mt-1">العملة: {{ currency }}</p>
    </div>
  </div>
</footer>
